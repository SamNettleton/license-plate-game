{
  "devDependencies": {
    "@testing-library/user-event": "^14.6.1",
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "start:frontend": "cd frontend && npm start",
    "start:backend": "cd backend && ./venv/bin/python -m uvicorn main:app --host 127.0.0.1 --port 8000 --reload",
    "dev": "concurrently -n \"VITE,FASTAPI\" -c \"blue,green\" \"npm run start:frontend\" \"npm run start:backend\"",
    "test": "npm run test:frontend && npm run test:backend",
    "test:watch": "concurrently -n \"FRONTEND,BACKEND\" -c \"magenta,cyan\" \"npm run test:frontend:watch\" \"npm run test:backend:watch\"",
    "test:frontend": "cd frontend && npx vitest run",
    "test:frontend:watch": "cd frontend && npm test",
    "test:backend": "cd backend && PYTHONPATH=$(pwd) ./venv/bin/pytest -v",
    "test:backend:watch": "cd backend && PYTHONPATH=$(pwd) ./venv/bin/ptw --runner pytest"
  }
}
